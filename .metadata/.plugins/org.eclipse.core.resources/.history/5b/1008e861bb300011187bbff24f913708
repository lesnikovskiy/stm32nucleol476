#include <stdint.h>

// Регистры тактирования
#define RCC_BASE              0x40021000UL
#define RCC_AHB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB1ENR1          (*(volatile uint32_t *)(RCC_BASE + 0x58))

// Регистры GPIOA
#define GPIOA_BASE            0x48000000UL
#define GPIOA_MODER           (*(volatile uint32_t *)(GPIOA_BASE + 0x00))
#define GPIOA_BSRR            (*(volatile uint32_t *)(GPIOA_BASE + 0x18))

// Регистры TIM6
#define TIM6_BASE             0x40001000UL
#define TIM6_CR1              (*(volatile uint32_t *)(TIM6_BASE + 0x00))
#define TIM6_DIER             (*(volatile uint32_t *)(TIM6_BASE + 0x0C))
#define TIM6_SR               (*(volatile uint32_t *)(TIM6_BASE + 0x10))
#define TIM6_PSC              (*(volatile uint32_t *)(TIM6_BASE + 0x28))
#define TIM6_ARR              (*(volatile uint32_t *)(TIM6_BASE + 0x2C))

// NVIC
#define NVIC_ISER1            (*(volatile uint32_t *)(0xE000E104UL))

void delay_loop(uint32_t count) {
	for (uint32_t i = 0; i < count; i++) {
		__asm("nop");
	}
}

int main(void) {
	// 1. Тактирование
	RCC_AHB2ENR |= (1U << 0);   // GPIOA
	RCC_APB1ENR1 |= (1U << 4);  // TIM6

	delay_loop(1000);

	// 2. Настройка PA5 как выход
	GPIOA_MODER &= ~(3U << 10);
	GPIOA_MODER |= (1U << 10);

	// Включаем LED сразу для проверки (чтобы убедиться, что GPIO работает)
	GPIOA_BSRR = (1U << 5);  // Включить LED

	delay_loop(1000000);  // Небольшая пауза, чтобы увидеть, что LED зажегся

	// 3. Настройка таймера
	TIM6_PSC = 8000 - 1;    // Делитель 8000
	TIM6_ARR = 10000 - 1;   // Период 1 секунда

	// 4. Разрешаем прерывания
	TIM6_DIER |= (1U << 0);              // Разрешить прерывание по обновлению
	NVIC_ISER1 |= (1U << (54 - 32));     // Включить в NVIC (бит 22)

	// 5. Запускаем таймер
	TIM6_CR1 |= (1U << 0);

	while (1) {
		__asm("wfi");
	}
}

void TIM6_DAC_IRQHandler(void) __attribute__((used));

// ПРАВИЛЬНОЕ имя обработчика для STM32L476RG
void TIM6_DAC_IRQHandler(void) {
	if (TIM6_SR & (1U << 0)) {
		(void) TIM6_SR;  // Очищаем флаг

		static uint8_t led_state = 0;

		if (led_state) {
			GPIOA_BSRR = (1U << (5 + 16));  // Выключить LED
			led_state = 0;
		} else {
			GPIOA_BSRR = (1U << 5);          // Включить LED
			led_state = 1;
		}
	}
}
