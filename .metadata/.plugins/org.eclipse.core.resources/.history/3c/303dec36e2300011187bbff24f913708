#include <stdint.h>

// Registers addresses
#define SCB_VTOR       (*(volatile uint32_t *)0xE000ED08UL)
#define CPACR          (*(volatile uint32_t *)0xE000ED88UL)
#define RCC_AHB2ENR    (*(volatile uint32_t *)0x4002104CUL)
#define RCC_APB2ENR    (*(volatile uint32_t *)0x40021060UL)
#define GPIOA_MODER    (*(volatile uint32_t *)0x48000000UL)
#define GPIOA_ODR      (*(volatile uint32_t *)0x48000014UL)
#define GPIOC_MODER    (*(volatile uint32_t *)0x48000800UL)
#define SYSCFG_EXTICR4 (*(volatile uint32_t *)0x40010014UL)
#define EXTI_IMR1      (*(volatile uint32_t *)0x40010400UL)
#define EXTI_FTSR1     (*(volatile uint32_t *)0x4001040CUL)
#define EXTI_PR1       (*(volatile uint32_t *)0x40010420UL)
#define NVIC_ISER1     (*(volatile uint32_t *)0xE000E104UL)
#define NVIC_ICPR1     (*(volatile uint32_t *)0xE000E284UL) // Interrupt Clear-Pending

void SystemInit(void) {
	CPACR |= ((3UL << 20) | (3UL << 22)); // Enable FPU
	SCB_VTOR = 0x08000000;                // Vector Table location
}

void delay(uint32_t count) {
	for (volatile uint32_t i = 0; i < count; i++)
		__asm("nop");
}

int main(void) {
	// 1. Clock Gating
	RCC_AHB2ENR |= (1U << 0) | (1U << 2); // GPIOA & GPIOC
	RCC_APB2ENR |= (1U << 0);             // SYSCFG
	delay(1000);

	// 2. GPIO Config (PA5 Output, PC13 Input)
	GPIOA_MODER &= ~(3U << 10);
	GPIOA_MODER |= (1U << 10);
	GPIOC_MODER &= ~(3U << 26);

	// 3. EXTI Mapping (Connect Line 13 to Port C)
	SYSCFG_EXTICR4 &= ~(0xFU << 4);
	SYSCFG_EXTICR4 |= (0x2U << 4);

	// 4. EXTI Trigger & Mask
	EXTI_FTSR1 |= (1U << 13); // Falling edge (button press)
	EXTI_IMR1 |= (1U << 13); // Unmask line 13

	// 5. NVIC Setup
	NVIC_ICPR1 |= (1U << (40 - 32)); // Clear any pending state for IRQ 40
	NVIC_ISER1 |= (1U << (40 - 32)); // Enable IRQ 40 (EXTI15_10)

	// Prove main is running: Turn LED ON
	GPIOA_ODR |= (1U << 5);

	while (1) {
		__asm("nop");
	}
}

void EXTI15_10_IRQHandler(void) {
	if (EXTI_PR1 & (1U << 13)) {
		EXTI_PR1 = (1U << 13); // Clear flag
		(void) EXTI_PR1;        // Sync
		__asm volatile ("dsb sy; isb");

		GPIOA_ODR ^= (1U << 5); // Toggle LED

		delay(200000); // Debounce
	}
}

