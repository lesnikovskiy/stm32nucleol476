#include <stdint.h>

// System and Debug
#define SCB_VTOR              (*(volatile uint32_t *)0xE000ED08UL)
#define CPACR                 (*(volatile uint32_t *)0xE000ED88UL)
#define DBGMCU_CR             (*(volatile uint32_t *)0xE0042004UL)

// RCC
#define RCC_AHB2ENR           (*(volatile uint32_t *)0x4002104CUL)
#define RCC_APB2ENR           (*(volatile uint32_t *)0x40021060UL)

// GPIOA (LED PA5)
#define GPIOA_MODER           (*(volatile uint32_t *)0x48000000UL)
#define GPIOA_ODR             (*(volatile uint32_t *)0x48000014UL)

// GPIOC (Button PC13)
#define GPIOC_MODER           (*(volatile uint32_t *)0x48000800UL)

// SYSCFG and EXTI
#define SYSCFG_EXTICR4        (*(volatile uint32_t *)0x40010014UL)
#define EXTI_IMR1             (*(volatile uint32_t *)0x40010400UL)
#define EXTI_FTSR1            (*(volatile uint32_t *)0x4001040CUL)
#define EXTI_PR1              (*(volatile uint32_t *)0x40010420UL)

// NVIC
#define NVIC_ISER1            (*(volatile uint32_t *)0xE000E104UL)

void SystemInit(void) {
}

// Simple delay for debouncing
void delay_debounce(uint32_t count) {
	for (volatile uint32_t i = 0; i < count; i++)
		__asm("nop");
}

int main(void) {
	// 0. Debug and Core Fixes
	DBGMCU_CR |= (1U << 0) | (1U << 1) | (1U << 2); // Keep debug connection alive
	SCB_VTOR = 0x08000000;
	CPACR |= ((3UL << 20) | (3UL << 22));           // Enable FPU
	__asm volatile ("dsb sy; isb");

	// 1. Clocks
	RCC_AHB2ENR |= (1U << 0) | (1U << 2); // Enable GPIOA and GPIOC
	RCC_APB2ENR |= (1U << 0);             // Enable SYSCFG
	delay_debounce(1000);

	// 2. PA5 Output (LED)
	GPIOA_MODER &= ~(3U << 10);
	GPIOA_MODER |= (1U << 10);

	// 3. PC13 Input (Button)
	GPIOC_MODER &= ~(3U << 26);

	// 4. SYSCFG: Map EXTI13 to Port C
	SYSCFG_EXTICR4 &= ~(0xFU << 4);
	SYSCFG_EXTICR4 |= (0x2U << 4);

	// 5. EXTI Setup
	EXTI_FTSR1 |= (1U << 13); // Trigger on Falling edge
	EXTI_IMR1 |= (1U << 13); // Enable interrupt line

	// 6. NVIC: EXTI15_10 (IRQ 40)
	NVIC_ISER1 |= (1U << (40 - 32));

	while (1) {
		__asm("nop");
	}
}

void EXTI15_10_IRQHandler(void) {
	// Check if Line 13 triggered the interrupt
	if (EXTI_PR1 & (1U << 13)) {

		// 1. Clear flag immediately
		EXTI_PR1 = (1U << 13);
		(void) EXTI_PR1; // Bus sync
		__asm volatile ("dsb sy; isb");

		// 2. Toggle LED
		GPIOA_ODR ^= (1U << 5);

		// 3. Software debounce: very important for mechanical buttons!
		// This prevents the LED from toggling 10 times in 1ms
		delay_debounce(50000);
	}
}
