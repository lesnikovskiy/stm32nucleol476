#include <stdint.h>

// --- Addresses (L476RG) ---
#define RCC_BASE              0x40021000UL
#define RCC_AHB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x60))

#define GPIOA_BASE            0x48000000UL
#define GPIOA_MODER           (*(volatile uint32_t *)(GPIOA_BASE + 0x00))
#define GPIOA_BSRR            (*(volatile uint32_t *)(GPIOA_BASE + 0x18))

#define GPIOC_BASE            0x48000800UL
#define GPIOC_MODER           (*(volatile uint32_t *)(GPIOC_BASE + 0x00))

// --- EXTI & SYSCFG (L4 Series) ---
#define SYSCFG_BASE           0x40010000UL
// EXTICR[3] (он же EXTICR4) управляет линиями 12, 13, 14, 15
#define SYSCFG_EXTICR4        (*(volatile uint32_t *)(SYSCFG_BASE + 0x14))

#define EXTI_BASE             0x40010400UL
#define EXTI_IMR1             (*(volatile uint32_t *)(EXTI_BASE + 0x00))
#define EXTI_FTSR1            (*(volatile uint32_t *)(EXTI_BASE + 0x0C))
// В L4 флаги прерываний сбрасываются в регистре PR1 (Pending Register)
#define EXTI_PR1              (*(volatile uint32_t *)(EXTI_BASE + 0x20))

// --- NVIC ---
#define NVIC_ISER1            (*(volatile uint32_t *)(0xE000E104UL))

int main(void) {
	// 1. Clocks: GPIOA, GPIOC and SYSCFG
	RCC_AHB2ENR |= (1U << 0) | (1U << 2);
	RCC_APB2ENR |= (1U << 0); // Enable SYSCFG clock

	// Critical: small delay for clock to stabilize
	for (volatile int i = 0; i < 1000; i++)
		;

	// 2. PA5 Output (LED)
	GPIOA_MODER &= ~(3U << 10);
	GPIOA_MODER |= (1U << 10);

	// 3. PC13 Input (Button)
	GPIOC_MODER &= ~(3U << 26);

	// 4. Connect EXTI Line 13 to Port C
	// Clear bits 4-7 (Line 13) and set to 0x2 (Port C)
	SYSCFG_EXTICR4 &= ~(0xFU << 4);
	SYSCFG_EXTICR4 |= (0x2U << 4);

	// 5. Setup EXTI
	EXTI_IMR1 |= (1U << 13); // Unmask Line 13
	EXTI_FTSR1 |= (1U << 13); // Trigger on Falling Edge

	// 6. NVIC: Enable EXTI15_10 (IRQ 40)
	NVIC_ISER1 |= (1U << (40 - 32));

	while (1) {
		// CPU is free for other tasks
		for (volatile int i = 0; i < 50000; i++)
			;
	}
}

// Handler name must match startup_stm32l476rgtx.s
void EXTI15_10_IRQHandler(void) {
	// Check if the interrupt was caused by Line 13
	if (EXTI_PR1 & (1U << 13)) {

		static int state = 0;
		if (state) {
			GPIOA_BSRR = (1U << 21); // LED OFF
			state = 0;
		} else {
			GPIOA_BSRR = (1U << 5);  // LED ON
			state = 1;
		}

		// CLEAR: Write 1 to the pending bit to acknowledge
		EXTI_PR1 |= (1U << 13);
	}
}
