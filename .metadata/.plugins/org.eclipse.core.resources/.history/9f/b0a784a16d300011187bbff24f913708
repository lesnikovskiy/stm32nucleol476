#include <stdint.h>

// Регистры тактирования
#define RCC_BASE              0x40021000UL
#define RCC_AHB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB1ENR1          (*(volatile uint32_t *)(RCC_BASE + 0x58)) // Для TIM6

// Регистры GPIOA
#define GPIOA_BASE            0x48000000UL
#define GPIOA_MODER           (*(volatile uint32_t *)(GPIOA_BASE + 0x00))
#define GPIOA_BSRR            (*(volatile uint32_t *)(GPIOA_BASE + 0x18))

// Регистры TIM6
#define TIM6_BASE             0x40001000UL
#define TIM6_CR1              (*(volatile uint32_t *)(TIM6_BASE + 0x00))
#define TIM6_DIER             (*(volatile uint32_t *)(TIM6_BASE + 0x0C)) // Разрешение прерываний
#define TIM6_SR               (*(volatile uint32_t *)(TIM6_BASE + 0x10)) // Статус (флаги)
#define TIM6_PSC              (*(volatile uint32_t *)(TIM6_BASE + 0x28)) // Делитель
#define TIM6_ARR              (*(volatile uint32_t *)(TIM6_BASE + 0x2C)) // Предел счета

// NVIC
#define NVIC_ISER1            (*(volatile uint32_t *)(0xE000E104UL))

// Простая функция задержки (опционально, для начальной инициализации)
void delay_loop(uint32_t count) {
	for (uint32_t i = 0; i < count; i++) {
		__asm("nop");
	}
}

int main(void) {
	// 1. Тактирование: GPIOA и TIM6
	RCC_AHB2ENR |= (1U << 0);   // Включаем GPIOA
	RCC_APB1ENR1 |= (1U << 4);  // Включаем TIM6

	// Небольшая задержка для стабилизации тактирования
	delay_loop(1000);

	// 2. Настройка LED (PA5) - выход push-pull
	GPIOA_MODER &= ~(3U << 10);  // Очищаем биты MODER5
	GPIOA_MODER |= (1U << 10);   // Устанавливаем как выход (01)

	// Изначально выключаем LED
	GPIOA_BSRR = (1U << (5 + 16));  // Сброс PA5

	// 3. Настройка Таймера для частоты 80 МГц (стандартная частота Nucleo-L476RG)
	// MSI по умолчанию 4 МГц, но ST-Link настраивает PLL на 80 МГц
	// TIM6 тактируется от APB1 (80 МГц, если APB1 prescaler = 1)

	TIM6_PSC = 8000 - 1;  // 80,000,000 / 8000 = 10,000 тиков в секунду (10 кГц)
	TIM6_ARR = 10000 - 1;   // Считаем до 10000 -> прерывание раз в секунду

	// Альтернативный вариант: мигание 2 раза в секунду (500 мс период)
	// TIM6_PSC = 8000 - 1;    // 10 кГц
	// TIM6_ARR = 5000 - 1;    // 500 мс

	// Альтернативный вариант: мигание 4 раза в секунду (250 мс период)
	// TIM6_PSC = 4000 - 1;    // 20 кГц (80M/4000)
	// TIM6_ARR = 5000 - 1;    // 5000/20000 = 0.25 сек

	// 4. Разрешаем прерывание в таймере и NVIC
	TIM6_DIER |= (1U << 0);          // Update Interrupt Enable
	NVIC_ISER1 |= (1U << (54 - 32)); // Номер прерывания TIM6 — 54 (бит 22 в ISER1)

	// 5. Запуск таймера
	TIM6_CR1 |= (1U << 0);           // CEN (Counter Enable)

	// Бесконечный цикл
	while (1) {
		__asm("wfi");
		// Ждем прерывания (спящий режим)
	}
}

// Обработчик прерывания таймера TIM6 (общий с DAC)
void TIM6_DAC_IRQHandler(void) {
	// Проверяем флаг обновления (опционально, но для надежности)
	if (TIM6_SR & (1U << 0)) {
		// ОЧИЩАЕМ флаг (обязательно!)
		// Способ 1: Прямая запись 0 (рекомендуется для STM32L4)
		TIM6_SR = 0;

		// Способ 2: Альтернативная очистка (тоже работает)
		// TIM6_SR &= ~(1U << 0);

		// Переключаем LED с использованием статической переменной
		static uint8_t led_state = 0;

		if (led_state) {
			// Выключаем LED (устанавливаем бит сброса)
			GPIOA_BSRR = (1U << (5 + 16));
			led_state = 0;
		} else {
			// Включаем LED (устанавливаем бит установки)
			GPIOA_BSRR = (1U << 5);
			led_state = 1;
		}
	}
}
