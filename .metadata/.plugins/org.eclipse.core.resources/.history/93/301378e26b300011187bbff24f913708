#include <stdint.h>

// --- Addresses ---
#define RCC_BASE              0x40021000UL
#define RCC_AHB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x60))

#define GPIOA_BASE            0x48000000UL
#define GPIOA_MODER           (*(volatile uint32_t *)(GPIOA_BASE + 0x00))
#define GPIOA_BSRR            (*(volatile uint32_t *)(GPIOA_BASE + 0x18))

#define GPIOC_BASE            0x48000800UL
#define GPIOC_MODER           (*(volatile uint32_t *)(GPIOC_BASE + 0x00))

#define SYSCFG_BASE           0x40010000UL
#define SYSCFG_EXTICR4        (*(volatile uint32_t *)(SYSCFG_BASE + 0x14))

#define EXTI_BASE             0x40010400UL
#define EXTI_IMR1             (*(volatile uint32_t *)(EXTI_BASE + 0x00))
#define EXTI_FTSR1            (*(volatile uint32_t *)(EXTI_BASE + 0x0C))

// ВАЖНО: В STM32L476 для очистки прерывания по спаду (Falling)
// нужно писать в регистр EXTI_FPR1 (смещение 0x24)
#define EXTI_FPR1             (*(volatile uint32_t *)(EXTI_BASE + 0x24))

#define NVIC_ISER1            (*(volatile uint32_t *)(0xE000E104UL))

int main(void) {
	// 1. Clocks
	RCC_AHB2ENR |= (1U << 0) | (1U << 2); // GPIOA, GPIOC
	RCC_APB2ENR |= (1U << 0);             // SYSCFG

	// for (volatile int i = 0; i < 500; i++); // Wait for clocks

	// 2. PA5 Output
	GPIOA_MODER &= ~(3U << 10);
	GPIOA_MODER |= (1U << 10);

	// 3. PC13 Input
	GPIOC_MODER &= ~(3U << 26);

	// 4. Connect Line 13 to Port C
	SYSCFG_EXTICR4 &= ~(0xFU << 4);
	SYSCFG_EXTICR4 |= (0x2U << 4);

	// 5. EXTI Setup
	EXTI_IMR1 |= (1U << 13); // Unmask
	EXTI_FTSR1 |= (1U << 13); // Falling edge

	// 6. NVIC Setup (IRQ 40)
	NVIC_ISER1 |= (1U << (40 - 32));

	while (1) {
		// Ничего не делаем, ждем прерывания
		__asm("nop");
	}
}

// Добавляем атрибут, чтобы компилятор точно не выкинул функцию
void EXTI15_10_IRQHandler(void) {
	// Проверяем флаг именно в Falling Pending Register
	if (EXTI_FPR1 & (1U << 13)) {

		static int state = 0;
		if (state) {
			GPIOA_BSRR = (1U << 21); // OFF
			state = 0;
		} else {
			GPIOA_BSRR = (1U << 5);  // ON
			state = 1;
		}

		// Очистка флага в L4: запись 1 в FPR1
		EXTI_FPR1 |= (1U << 13);
	}
}
