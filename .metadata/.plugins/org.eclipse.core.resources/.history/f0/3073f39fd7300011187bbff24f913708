#include <stdint.h>

// --- Addresses (L476RG) ---
#define RCC_BASE              0x40021000UL
#define RCC_AHB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x60))

#define GPIOA_BASE            0x48000000UL
#define GPIOA_MODER           (*(volatile uint32_t *)(GPIOA_BASE + 0x00))
#define GPIOA_BSRR            (*(volatile uint32_t *)(GPIOA_BASE + 0x18))

#define GPIOC_BASE            0x48000800UL
#define GPIOC_MODER           (*(volatile uint32_t *)(GPIOC_BASE + 0x00))

#define SYSCFG_BASE           0x40010000UL
#define SYSCFG_EXTICR4        (*(volatile uint32_t *)(SYSCFG_BASE + 0x14))

#define EXTI_BASE             0x40010400UL
#define EXTI_IMR1             (*(volatile uint32_t *)(EXTI_BASE + 0x00))
#define EXTI_FTSR1            (*(volatile uint32_t *)(EXTI_BASE + 0x0C))
#define EXTI_PR1              (*(volatile uint32_t *)(EXTI_BASE + 0x20)) // Pending Register

#define NVIC_ISER1            (*(volatile uint32_t *)(0xE000E104UL))

int main(void) {
    // 1. Clocks: GPIOA, GPIOC, SYSCFG
    RCC_AHB2ENR |= (1U << 0) | (1U << 2);
    RCC_APB2ENR |= (1U << 0);

    for(volatile int i = 0; i < 1000; i++); // Даем время тактированию

    // 2. PA5 Output (LED)
    GPIOA_MODER &= ~(3U << 10);
    GPIOA_MODER |=  (1U << 10);

    // 3. PC13 Input (Button)
    GPIOC_MODER &= ~(3U << 26);

    // 4. SYSCFG: Connect Line 13 to Port C (0x2)
    // Очищаем биты 4-7 и ставим 0010
    SYSCFG_EXTICR4 &= ~(0xFU << 4);
    SYSCFG_EXTICR4 |=  (0x2U << 4);

    // 5. EXTI Setup
    EXTI_FTSR1 |= (1U << 13); // Trigger on falling edge
    EXTI_IMR1  |= (1U << 13); // Interrupt Mask (Enable)

    // 6. NVIC: EXTI15_10 is IRQ 40 (40-32 = 8 bit of ISER1)
    NVIC_ISER1 = (1U << 8);

    while (1) {
        // Если прерывание НЕ работает, но кнопка физически жива,
        // этот код будет зажигать LED при нажатии (для теста):
        // if (!((*(volatile uint32_t *)(0x48000810)) & (1 << 13))) GPIOA_BSRR = (1 << 5);
    }
}

// Попробуй добавить перед функцией этот атрибут, чтобы исключить ошибки линковки
void EXTI15_10_IRQHandler(void) {
    // Проверяем флаг в PR1
    if (EXTI_PR1 & (1U << 13)) {

        static int state = 0;
        if (state) {
            GPIOA_BSRR = (1U << 21); // OFF
            state = 0;
        } else {
            GPIOA_BSRR = (1U << 5);  // ON
            state = 1;
        }

        // Очистка: в STM32 PR сбрасывается записью единицы
        EXTI_PR1 = (1U << 13);
    }
}
