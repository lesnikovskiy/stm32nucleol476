#include <stdint.h>

// Vector Table and System Control Registers
#define SCB_VTOR              (*(volatile uint32_t *)0xE000ED08UL)
#define CPACR                 (*(volatile uint32_t *)0xE000ED88UL) // Coprocessor Access Control Register (FPU)

// Clock Control Registers (RCC)
#define RCC_BASE              0x40021000UL
#define RCC_AHB2ENR           (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB1ENR1          (*(volatile uint32_t *)(RCC_BASE + 0x58))

// GPIOA Registers
#define GPIOA_BASE            0x48000000UL
#define GPIOA_MODER           (*(volatile uint32_t *)(GPIOA_BASE + 0x00))
#define GPIOA_ODR             (*(volatile uint32_t *)(GPIOA_BASE + 0x14))
#define GPIOA_BSRR            (*(volatile uint32_t *)(GPIOA_BASE + 0x18))

// TIM6 Basic Timer Registers
#define TIM6_BASE             0x40001000UL
#define TIM6_CR1              (*(volatile uint32_t *)(TIM6_BASE + 0x00))
#define TIM6_DIER             (*(volatile uint32_t *)(TIM6_BASE + 0x0C))
#define TIM6_SR               (*(volatile uint32_t *)(TIM6_BASE + 0x10))
#define TIM6_EGR              (*(volatile uint32_t *)(TIM6_BASE + 0x14))
#define TIM6_CNT              (*(volatile uint32_t *)(TIM6_BASE + 0x24))
#define TIM6_PSC              (*(volatile uint32_t *)(TIM6_BASE + 0x28))
#define TIM6_ARR              (*(volatile uint32_t *)(TIM6_BASE + 0x2C))

// NVIC (Nested Vectored Interrupt Controller)
#define NVIC_ISER1            (*(volatile uint32_t *)(0xE000E104UL))

// Simple software delay loop using volatile to prevent compiler optimization
void delay_loop(uint32_t count) {
	for (volatile uint32_t i = 0; i < count; i++) {
		__asm("nop");
	}
}

int main(void) {
	// 1. System Setup
	SCB_VTOR = 0x08000000; // Explicitly set Vector Table to the start of Flash memory

	// Enable FPU (Coprocessor 10 and 11): Essential for L4 series to prevent HardFault during ISR
	CPACR |= ((3UL << 20) | (3UL << 22));

	// 2. Enable Peripheral Clocks
	RCC_AHB2ENR |= (1U << 0);   // Enable GPIOA Clock
	RCC_APB1ENR1 |= (1U << 4);  // Enable TIM6 Clock

	delay_loop(1000); // Stabilization delay for peripherals

	// 3. Configure PA5 (Green LED) and PA6 (Logic Analyzer) as Outputs
	GPIOA_MODER &= ~((3U << 10) | (3U << 12)); // Clear mode bits for pins 5 and 6
	GPIOA_MODER |= ((1U << 10) | (1U << 12));  // Set mode to Output (01)

	// Hardware Check: Flash the LED once to prove GPIO and Main loop are running
	GPIOA_BSRR = (1U << 5);         // LED ON
	delay_loop(1000000);
	GPIOA_BSRR = (1U << (5 + 16));  // LED OFF

	// 4. Timer Configuration (Based on 4MHz default MSI clock)
	TIM6_CR1 = 0;           // Reset Control Register (Ensures One-Pulse Mode is OFF)
	TIM6_PSC = 400 - 1;     // 4,000,000 / 400 = 10,000 Hz internal counter frequency
	TIM6_ARR = 2000 - 1;    // 10,000 / 2,000 = 5 Hz interrupt frequency (Period 0.2s)

	TIM6_CNT = 0;           // Initialize counter to zero
	TIM6_EGR |= (1U << 0);  // Trigger Update Event to latch PSC and ARR values
	TIM6_SR &= ~(1U << 0);  // Manually clear the flag caused by the EGR update

	// 5. NVIC and Timer Interrupt Enable
	NVIC_ISER1 |= (1U << (54 - 32)); // Enable IRQ 54 in NVIC ISER1
	TIM6_DIER |= (1U << 0);          // Enable Timer Update Interrupt (UIE)

	// 6. Start the Timer
	TIM6_CR1 |= (1U << 0); // Set CEN (Counter Enable)

	while (1) {
		// Main loop is idle; toggling is handled by the Interrupt Service Routine (ISR)
		__asm("nop");
	}
}

// Handler name must match exactly with the startup_stm32l476rgtx.s vector table
void TIM6_DAC_IRQHandler(void) __attribute__((used));

void TIM6_DAC_IRQHandler(void) {
	// Check if the Update Interrupt Flag is active
	if (TIM6_SR & (1U << 0)) {
		TIM6_SR &= ~(1U << 0); // Clear the flag in the hardware register

		// Memory barriers: Ensure flag clearing is finalized before CPU tries to exit the ISR
		__asm volatile ("dsb sy");
		// Data Synchronization Barrier
		__asm volatile ("isb");
		// Instruction Synchronization Barrier

		// Toggle both Logic Analyzer pin (PA6) and User LED (PA5)
		GPIOA_ODR ^= (1U << 6);
		GPIOA_ODR ^= (1U << 5);
	}
}

