#include <stdint.h>

// Все необходимые адреса регистров (L476RG)
#define SCB_VTOR       (*(volatile uint32_t *)0xE000ED08)
#define CPACR          (*(volatile uint32_t *)0xE000ED88)
#define RCC_AHB2ENR    (*(volatile uint32_t *)0x4002104C)
#define RCC_APB2ENR    (*(volatile uint32_t *)0x40021060)
#define GPIOA_MODER    (*(volatile uint32_t *)0x48000000)
#define GPIOA_ODR      (*(volatile uint32_t *)0x48000014)
#define GPIOC_MODER    (*(volatile uint32_t *)0x48000800)
#define GPIOC_PUPDR    (*(volatile uint32_t *)0x4800080C)
#define SYSCFG_EXTICR4 (*(volatile uint32_t *)0x40010014)
#define EXTI_IMR1      (*(volatile uint32_t *)0x40010400)
#define EXTI_RTSR1     (*(volatile uint32_t *)0x40010408)
#define EXTI_FTSR1     (*(volatile uint32_t *)0x4001040C)
#define EXTI_PR1       (*(volatile uint32_t *)0x40010420)
#define NVIC_ISER1     (*(volatile uint32_t *)0xE000E104)

void SystemInit(void) {
	CPACR |= (0xF << 20); // Enable FPU
	SCB_VTOR = 0x08000000;
}

void delay(void) {
	for (volatile int i = 0; i < 200000; i++)
		;
}

int main(void) {
	// 1. Включаем тактирование (AHB2 для портов, APB2 для SYSCFG)
	RCC_AHB2ENR |= (1 << 0) | (1 << 2); // GPIOA, GPIOC
	RCC_APB2ENR |= (1 << 0);            // SYSCFG clock
	delay();

	// 2. Настройка PA5 (LED) - Выход
	GPIOA_MODER &= ~(3 << 10);
	GPIOA_MODER |= (1 << 10);

	// 3. Настройка PC13 (Button) - Вход + Pull-up (как в HAL)
	GPIOC_MODER &= ~(3 << 26);
	GPIOC_PUPDR &= ~(3 << 26);
	GPIOC_PUPDR |= (1 << 26);

	// 4. Связываем Линию 13 с Портом C (0x2)
	SYSCFG_EXTICR4 &= ~(0xF << 4);
	SYSCFG_EXTICR4 |= (0x2 << 4);

	// 5. Настройка EXTI (Оба фронта для надежности)
	EXTI_IMR1 |= (1 << 13); // Разрешить прерывание в EXTI
	EXTI_FTSR1 |= (1 << 13); // Спад (нажатие)
	EXTI_RTSR1 |= (1 << 13); // Подъем (отпускание)
	EXTI_PR1 = (1 << 13); // Сброс флагов

	// 6. Разрешение в NVIC (IRQ 40)
	NVIC_ISER1 = 0x00000100; // Прямая запись 8-го бита

	// Проверка записи в NVIC
	if (NVIC_ISER1 & 0x100) {
		GPIOA_ODR |= (1 << 5); // Светодиод загорится при старте
	}

	// Глобальное разрешение прерываний в ядре
	__asm volatile ("cpsie i");

	while (1) {
		__asm("nop");
	}
}

// Попробуйте переименовать функцию В ТОЧНОСТИ как в стартапе,
// если там есть малейшее отличие (например, без подчеркиваний или с DAC1)
void EXTI15_10_IRQHandler(void) {
	if (EXTI_PR1 & (1 << 13)) {
		EXTI_PR1 = (1 << 13); // Сброс
		(void) EXTI_PR1;       // Задержка шины

		GPIOA_ODR ^= (1 << 5); // Инвертируем светодиод
		delay();               // Антидребезг
	}
}

