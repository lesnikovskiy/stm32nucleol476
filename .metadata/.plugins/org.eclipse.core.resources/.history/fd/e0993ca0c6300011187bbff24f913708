#include <stdint.h>

// Vector Table and FPU
#define SCB_VTOR              (*(volatile uint32_t *)0xE000ED08UL)
#define CPACR                 (*(volatile uint32_t *)0xE000ED88UL)

// Clock Control (RCC)
#define RCC_AHB2ENR           (*(volatile uint32_t *)0x4002104CUL)
#define RCC_APB1ENR1          (*(volatile uint32_t *)0x40021058UL)

// GPIOA
#define GPIOA_MODER           (*(volatile uint32_t *)0x48000000UL)
#define GPIOA_ODR             (*(volatile uint32_t *)0x48000014UL)

// TIM6
#define TIM6_BASE             0x40001000UL
#define TIM6_CR1              (*(volatile uint32_t *)(TIM6_BASE + 0x00))
#define TIM6_DIER             (*(volatile uint32_t *)(TIM6_BASE + 0x0CUL))
#define TIM6_SR               (*(volatile uint32_t *)(TIM6_BASE + 0x10UL))
#define TIM6_EGR              (*(volatile uint32_t *)(TIM6_BASE + 0x14UL))
#define TIM6_PSC              (*(volatile uint32_t *)(TIM6_BASE + 0x28UL))
#define TIM6_ARR              (*(volatile uint32_t *)(TIM6_BASE + 0x2CUL))

// NVIC
#define NVIC_ISER1            (*(volatile uint32_t *)0xE000E104UL)

void SystemInit(void) {
} // Overrides the weak symbol in startup

void delay_loop(uint32_t count) {
	for (volatile uint32_t i = 0; i < count; i++)
		__asm("nop");
}

int main(void) {
	// 1. Fundamental Hardware Fixes
	SCB_VTOR = 0x08000000;                // Point to Flash start
	CPACR |= ((3UL << 20) | (3UL << 22)); // Enable FPU
	__asm volatile ("dsb sy; isb");

	// 2. Enable Clocks
	RCC_AHB2ENR |= (1U << 0);   // GPIOA
	RCC_APB1ENR1 |= (1U << 4);  // TIM6
	delay_loop(1000);

	// 3. Configure PA5 (LED) and PA6 (Analyzer)
	GPIOA_MODER &= ~((3U << 10) | (3U << 12));
	GPIOA_MODER |= ((1U << 10) | (1U << 12));

	// 4. Timer Setup (4MHz MSI default clock)
	TIM6_CR1 = 0;           // Clear Control Register
	TIM6_PSC = 400 - 1;     // 4MHz / 400 = 10,000 Hz count
	TIM6_ARR = 2000 - 1;    // 10,000 / 2,000 = 0.2s interval

	TIM6_EGR |= (1U << 0);  // Trigger update event to load registers
	TIM6_SR &= ~(1U << 0);  // Clear hardware flag

	// 5. NVIC Enable (IRQ 54 is bit 22 of ISER1)
	NVIC_ISER1 |= (1U << (54 - 32));
	TIM6_DIER |= (1U << 0);          // Enable Timer Update Interrupt

	// 6. Start Timer
	TIM6_CR1 |= (1U << 0);

	while (1) {
		__asm("nop");
	}
}

/**
 * CRITICAL: The name must match your startup_stm32l476rgtx.s exactly!
 */
void TIM6_DACUNDER_IRQHandler(void) {
	// Check if Update Interrupt Flag is set
	if (TIM6_SR & (1U << 0)) {
		TIM6_SR &= ~(1U << 0); // Clear the flag
		(void) TIM6_SR;         // Dummy read for bus synchronization
		__asm volatile ("dsb sy");

		// Toggle Outputs
		GPIOA_ODR ^= (1U << 6); // Saleae Logic Analyzer Pin
		GPIOA_ODR ^= (1U << 5); // Nucleo Green LED
	}
}
