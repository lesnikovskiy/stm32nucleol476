#include <stdint.h>

// System Control Block & FPU
#define SCB_VTOR              (*(volatile uint32_t *)0xE000ED08UL)
#define CPACR                 (*(volatile uint32_t *)0xE000ED88UL)

// Clock Control (RCC)
#define RCC_AHB2ENR           (*(volatile uint32_t *)0x4002104CUL)
#define RCC_APB1ENR1          (*(volatile uint32_t *)0x40021058UL)

// GPIOA
#define GPIOA_MODER           (*(volatile uint32_t *)0x48000000UL)
#define GPIOA_ODR             (*(volatile uint32_t *)0x48000014UL)
#define GPIOA_BSRR            (*(volatile uint32_t *)0x48000018UL)

// TIM6
#define TIM6_BASE             0x40001000UL
#define TIM6_CR1              (*(volatile uint32_t *)(TIM6_BASE + 0x00))
#define TIM6_DIER             (*(volatile uint32_t *)(TIM6_BASE + 0x0C))
#define TIM6_SR               (*(volatile uint32_t *)(TIM6_BASE + 0x10))
#define TIM6_EGR              (*(volatile uint32_t *)(TIM6_BASE + 0x14))
#define TIM6_PSC              (*(volatile uint32_t *)(TIM6_BASE + 0x28))
#define TIM6_ARR              (*(volatile uint32_t *)(TIM6_BASE + 0x2C))

// NVIC
#define NVIC_ISER1            (*(volatile uint32_t *)0xE000E104UL)

// Redefine SystemInit to prevent the startup file from jumping to nowhere
void SystemInit(void) {
}

void delay_loop(uint32_t count) {
	for (volatile uint32_t i = 0; i < count; i++)
		__asm("nop");
}

int main(void) {
	// 1. Fundamental Hardware Fixes
	SCB_VTOR = 0x08000000;                // Point to Flash start
	CPACR |= ((3UL << 20) | (3UL << 22)); // Enable FPU (Coprocessor 10 & 11)
	__asm volatile ("dsb sy; isb");

	// 2. Enable Clocks
	RCC_AHB2ENR |= (1U << 0);   // GPIOA
	RCC_APB1ENR1 |= (1U << 4);  // TIM6
	delay_loop(1000);

	// 3. Configure PA5 (LED) and PA6 (Analyzer)
	GPIOA_MODER &= ~((3U << 10) | (3U << 12));
	GPIOA_MODER |= ((1U << 10) | (1U << 12));

	// 4. Timer Setup (4MHz MSI)
	TIM6_CR1 = 0;           // Clear Control Register
	TIM6_PSC = 400 - 1;     // 10kHz count frequency
	TIM6_ARR = 2000 - 1;    // 0.2s interval

	TIM6_EGR |= (1U << 0);  // Update shadow registers
	TIM6_SR &= ~(1U << 0);  // Clear flag

	// 5. NVIC Enable
	NVIC_ISER1 |= (1U << (54 - 32)); // IRQ 54
	TIM6_DIER |= (1U << 0);          // Enable Interrupt

	// 6. Start Timer
	TIM6_CR1 |= (1U << 0);

	while (1) {
		__asm("nop");
	}
}

/**
 * Use both names to be safe. If your startup file uses one or the other,
 * the linker will link it correctly.
 */
void TIM6_DAC_IRQHandler(void) {
	if (TIM6_SR & (1U << 0)) {
		TIM6_SR &= ~(1U << 0); // Clear Flag
		(void) TIM6_SR;         // Delay for bus sync
		__asm volatile ("dsb sy");

		GPIOA_ODR ^= (1U << 6);
		GPIOA_ODR ^= (1U << 5);
	}
}

// Some L4 startup files use this name instead
void TIM6_DAC1_IRQHandler(void) {
	TIM6_DAC_IRQHandler();
}
}

